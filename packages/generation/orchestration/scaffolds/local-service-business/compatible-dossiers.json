{
  "required": ["contact-cta"],
  "recommended": [
    "service-list",
    "service-area",
    "reviews",
    "trust-badges",
    "faq"
  ],
  "conditional": [
    {
      "id": "emergency-cta",
      "when": "business has urgent response use case (electrician, plumber, locksmith)"
    },
    {
      "id": "before-after-gallery",
      "when": "visual proof improves conversion (painter, cleaner, landscaper)"
    },
    {
      "id": "booking-request",
      "when": "appointments are relevant"
    }
  ],
  "disallowedByDefault": [
    "pricing-table-saas",
    "dashboard-shell",
    "auth-flow",
    "checkout"
  ]
}
