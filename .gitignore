.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

node_modules/
dist/
build/
.next/
out/
.turbo/
!apps/viewser/app/api/build/
!apps/viewser/app/api/build/route.ts
# Reserve the destination for the B13a architecture-move (see
# docs/known-issues.md). The bare `build/` rule above matches at any
# depth, including packages/generation/build/, which would silently
# drop the new package the day the move PR lands. Pre-allow it now so
# the trap is gone before anyone hits it.
!packages/generation/build/
!packages/generation/build/**

.env
.env.*
!.env.example

data/runs/
data/output/
data/versions/

# Lokal eval-suite output (scripts/run_eval_suite.py + backoffice
# eval-knapparna). Per-suite summary och manuella scorecards genereras
# på operatörens maskin och versionsas inte. Mapparna behålls i git via
# .gitkeep så backoffice-vyn alltid har en plats att skriva till.
# data/evals/generated/<evalRunId>/<siteId>/ är per-case Next.js-output
# som full-mode-bygget skapar för att tvinga ren npm install.
data/evals/eval-runs/*.json
data/evals/manual-scorecards/*.json
data/evals/generated/
# scripts/run_scaffold_selection_probe.py output. Same kategori: lokal
# observability per körning, inte arkiverat i git. .gitkeep behåller mappen.
data/evals/scaffold-probe/*.json
data/evals/scaffold-probe/*.md

audits/
data/prompt-inputs/
data/embedding-index/
# Operatöruppladdade assets — bytes finns endast lokalt (LocalAssetStore)
# eller i Vercel Blob (VercelBlobAssetStore). Manifest + originals/optimized
# regenereras vid behov; ingen anledning att versionera 2 MB+ per upload.
data/uploads/
# Backoffice + script-genererade soft dossier-kandidater. Skapas av
# scripts/generate_dossier_candidate.py och Backoffice "create soft
# dossier candidate"-flödet under operator-review. Samma kategori som
# data/runs/ + data/uploads/: per-operatör scratch-yta. Promotade
# kandidater hamnar i packages/generation/orchestration/dossiers/<id>/
# via en separat promotion-flow och committas där. Om en specifik
# kandidat ska delas i repo:t läggs den till med `git add -f`.
data/dossier-candidates/
.generated/
*.log

.DS_Store
Thumbs.db
.idea/
*.swp

.streamlit/secrets.toml

# Per-developer VS Code/Cursor overrides. Shared editor settings live in
# .vscode/settings.json (committed); machine-local terminal paths and
# similar must go in User Settings or *.local.json instead.
.vscode/*.local.json

# Cursor MCP credentials. When Cursor authenticates an MCP server it
# writes OAuth tokens into .cursor/mcp.json; that file must NEVER be
# committed even if a developer accidentally `git add`s it. The shared
# .cursor/ rules + .cursor/settings.json + .cursor/BUGBOT.md ARE
# committed (team-shared editor rules); only the per-machine MCP
# credential file is excluded here.
.cursor/mcp.json

# Agent-/operator-lokala plan-filer som CreatePlan-tool genererar
# (.cursor/plans/<name>_<hash>.plan.md). Snabbarbetsartefakter per
# session; ska aldrig committas. Samma kategori som .cursor/mcp.json
# ovan: per-machine state, inte shared editor-config.
.cursor/plans/

# Operatör-/agent-lokala temp-noteringar med .cursor/tmp_-prefix
# (t.ex. tmp_known_issues_pr52.md). Samma kategori som .cursor/plans/
# ovan: per-session scratch som scripts/check_term_coverage.py redan
# skippar (rad 656-661).
.cursor/tmp_*

.tmp-*
.tmp.*
.commit-msg.tmp
konversation.txt
.review-*/

# Agent-till-agent handover-noteringar på repo-toppnivå
# (t.ex. handover-stackblitz-2026-05-25.md). Transient session-state
# mellan parallella agenter / sessioner — innehåller browser/SDK-
# specifika feature-namn och pågående debug-spår som inte hör hemma
# i versionshistoriken. Samma kategori som mer_info.txt-mönstret:
# operatören kan ha filen lokalt, men den committas aldrig.
# scripts/check_term_coverage.py har spegelfix som skipar filerna
# så agent-narrative inte felklassas som okända domänbegrepp.
handover-*.md

# Lokal mini-eval-output (verify_run/eval-runners skriver hit). Stora
# artefakter per körning, samma kategori som data/runs/ men för
# operatör-iterationer utanför canonical history.
eval-tmp/

# Operator-only reference workspace - copies/forks of MIN_IDE-style examples.
# Files in MIN_IDE/ are read-only inspiration and never get committed.
MIN_IDE/

# Starter-source zips/tarballs - we keep README.md per starter but raw source
# archives (e.g. data/starters/commerce-base/commerce-main.zip) are operator-
# local material and must never be committed. The harmonised starter content
# lives directly under data/starters/<id>/ once a starter-harmonisation sprint
# unzips and ports it.
data/starters/**/*.zip
data/starters/**/*.tar.gz

# Taxonomy-källfiler (Excel/CSV som extraheras till committad JSON-spegel).
# Workflow för SNI 2025: operatören laddar ner SCB:s xlsx, kör
# scripts/extract_sni_2025.py -> sni-2025.v1.json, och raderar sedan
# xlsx:en lokalt. JSON:en är canonical. Defensivt mönster så ett
# framtida re-extract inte råkar committa xlsx-källan.
data/taxonomies/**/*.xlsx
data/taxonomies/**/*.csv

övrigt/

# Guard against accidental commits of local scout helpers and Windows temp outputs.
**/viewser_overlay_scout.py
**/viewser-scout-runs/

# Operator-local utility scripts (tree-printers, scratch tools för LLM-context).
# Operatör äger filerna lokalt; om de ska committas tas raden bort medvetet.
# Pattern matchar tree_v2.py / tree_v3.py-stil men INTE scripts/tree_view.py
# (som är den committade delade utility-versionen).
tree_v[0-9]*.py
