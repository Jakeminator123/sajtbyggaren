{
  "$schema": "../schemas/page-quality-traits.schema.json",
  "policyId": "page-quality-traits.v1",
  "version": 1,
  "status": "draft-but-authoritative",
  "qualityTarget": {
    "scoreScale": "0-10",
    "targetScore": 9.0,
    "gateScore": 8.6,
    "blockBelow": 7.5,
    "label": "worldclass-lite",
    "meaning": "Serious business website quality close to top-tier builders, with less wow but stronger business clarity."
  },
  "scoring": {
    "method": "weighted_average",
    "weightsTotal": 100,
    "rounding": "one_decimal",
    "promotionRule": "Promote only when weighted score >= gateScore and no blocking trait is below 7.5."
  },
  "traits": [
    {
      "id": "business_fit",
      "name": "Business fit",
      "weight": 10,
      "ownerPackage": "packages/generation",
      "definition": "The page clearly fits the user's business, local context, offer, and customer type.",
      "positiveSignals": [
        "specific services",
        "realistic customer problems",
        "clear local or niche cues"
      ],
      "negativeSignals": [
        "generic SaaS copy",
        "wrong industry assumptions",
        "template text"
      ],
      "checkMethods": [
        "llm_judge",
        "manual_review"
      ]
    },
    {
      "id": "visual_hierarchy",
      "name": "Visual hierarchy",
      "weight": 10,
      "ownerPackage": "packages/generation",
      "definition": "The page has an obvious priority order: hero, proof, offer, details, CTA.",
      "positiveSignals": [
        "strong hero",
        "clear sections",
        "scan-friendly layout"
      ],
      "negativeSignals": [
        "flat blocks",
        "unclear first action",
        "no section rhythm"
      ],
      "checkMethods": [
        "screenshot_review",
        "llm_judge"
      ]
    },
    {
      "id": "conversion_clarity",
      "name": "Conversion clarity",
      "weight": 10,
      "ownerPackage": "packages/builder",
      "definition": "Visitors understand what to do next and why it matters.",
      "positiveSignals": [
        "one primary CTA",
        "low-friction contact path",
        "benefit-first CTA copy"
      ],
      "negativeSignals": [
        "many equal CTAs",
        "unclear offer",
        "CTA hidden below fold"
      ],
      "checkMethods": [
        "dom_scan",
        "manual_review"
      ]
    },
    {
      "id": "content_specificity",
      "name": "Content specificity",
      "weight": 10,
      "ownerPackage": "packages/generation",
      "definition": "Copy feels written for this company category, not a generic placeholder website.",
      "positiveSignals": [
        "specific objections",
        "concrete service details",
        "credible microcopy"
      ],
      "negativeSignals": [
        "lorem ipsum",
        "AI-sounding filler",
        "repeated vague claims"
      ],
      "checkMethods": [
        "llm_judge",
        "text_scan"
      ]
    },
    {
      "id": "trust_and_proof",
      "name": "Trust and proof",
      "weight": 10,
      "ownerPackage": "packages/generation",
      "definition": "The page gives a business visitor enough proof to believe the offer.",
      "positiveSignals": [
        "testimonials",
        "process proof",
        "certifications",
        "before-after",
        "case snippets"
      ],
      "negativeSignals": [
        "unsupported claims",
        "fake-looking stats",
        "no credibility layer"
      ],
      "checkMethods": [
        "llm_judge",
        "manual_review"
      ]
    },
    {
      "id": "responsive_composition",
      "name": "Responsive composition",
      "weight": 10,
      "ownerPackage": "packages/preview-runtime",
      "definition": "Layout remains strong on mobile, tablet, and desktop without hidden broken states.",
      "positiveSignals": [
        "stable mobile nav",
        "no overflow",
        "balanced spacing across viewports"
      ],
      "negativeSignals": [
        "horizontal scroll",
        "clipped hero",
        "overlapping cards"
      ],
      "checkMethods": [
        "viewport_screenshot",
        "playwright"
      ]
    },
    {
      "id": "accessibility_baseline",
      "name": "Accessibility baseline",
      "weight": 10,
      "ownerPackage": "packages/builder",
      "definition": "The generated site respects baseline accessibility: semantics, contrast, labels, keyboard path.",
      "positiveSignals": [
        "semantic landmarks",
        "button labels",
        "image alt strategy",
        "contrast"
      ],
      "negativeSignals": [
        "div-only buttons",
        "missing labels",
        "low contrast text"
      ],
      "checkMethods": [
        "axe",
        "dom_scan",
        "manual_review"
      ]
    },
    {
      "id": "performance_sanity",
      "name": "Performance sanity",
      "weight": 10,
      "ownerPackage": "packages/preview-runtime",
      "definition": "The page avoids unnecessary heavy assets and expensive client-side behavior.",
      "positiveSignals": [
        "small asset count",
        "lazy media",
        "limited heavy animation"
      ],
      "negativeSignals": [
        "giant images",
        "too many libraries",
        "blocking scripts"
      ],
      "checkMethods": [
        "build_stats",
        "lighthouse_smoke"
      ]
    },
    {
      "id": "interaction_polish",
      "name": "Interaction polish",
      "weight": 10,
      "ownerPackage": "packages/web",
      "definition": "Interactive states feel intentional without distracting from business goals.",
      "positiveSignals": [
        "hover/focus states",
        "smooth but restrained motion",
        "clear form feedback"
      ],
      "negativeSignals": [
        "random animation",
        "dead controls",
        "jumpy layout"
      ],
      "checkMethods": [
        "manual_review",
        "playwright"
      ]
    },
    {
      "id": "technical_correctness",
      "name": "Technical correctness",
      "weight": 10,
      "ownerPackage": "packages/builder",
      "definition": "The site builds, routes correctly, imports only allowed packages, and has no runtime-breaking code.",
      "positiveSignals": [
        "typecheck pass",
        "build pass",
        "valid routes",
        "no broken imports"
      ],
      "negativeSignals": [
        "compile error",
        "missing component",
        "wrong path alias",
        "runtime exception"
      ],
      "checkMethods": [
        "typecheck",
        "build",
        "route_scan",
        "preview_smoke"
      ]
    }
  ]
}
