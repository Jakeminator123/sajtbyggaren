OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_INPUT_USD_PER_1K=0
OPENAI_OUTPUT_USD_PER_1K=0
VIEWSER_RUNS_DIR=../../data/runs
VIEWSER_MAX_CHAT_TOKENS=1500
VIEWSER_ALLOW_NON_LOCALHOST=false

# --- Asset store ---
# "local" (default) lagrar uppladdade bilder under data/uploads/<siteId>/<assetId>/.
# "vercel-blob" lagrar dem i en Vercel Blob-store och kr\u00e4ver BLOB_READ_WRITE_TOKEN.
# Frontend-koden \u00e4r identisk f\u00f6r b\u00e5da driver:s; build_site.py f\u00f6redrar
# ref.sourceUrl framf\u00f6r disk n\u00e4r f\u00e4ltet \u00e4r satt (se docs/backend-handoff.md).
ASSET_STORE_DRIVER=local
BLOB_READ_WRITE_TOKEN=

# --- AI image generation (POST /api/generate-image) ---
# OPENAI_API_KEY \u00e5teranv\u00e4nds (samma nyckel som briefModel/planningModel).
# OPENAI_IMAGE_MODEL: "gpt-image-1.5" (default, ~20% billigare \u00e4n gpt-image-1)
#                     eller "gpt-image-1" (h\u00f6gre detalj).
# OPENAI_IMAGE_QUALITY: "low" (snabbt, $0.005-0.01/img), "medium" (default,
#                        $0.04-0.06/img), "high" ($0.17-0.25/img), eller "auto".
# Per-role storlek styrs i route-handlern (logo 1024\u00b2, hero 1536\u00d71024 etc).
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_QUALITY=medium
