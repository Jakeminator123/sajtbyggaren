{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "ignoreCommand": "BASE=\"${VERCEL_GIT_PREVIOUS_SHA:-HEAD^}\"; git diff --quiet \"$BASE\" HEAD -- . ../../governance/policies ../../packages/generation/orchestration/scaffolds ../../docs/openclaw-workspace",
  "git": {
    "deploymentEnabled": {
      "feat/*": false,
      "feat/**": false,
      "cursor/*": false,
      "cursor/**": false,
      "backup-*": false,
      "hosted-sandbox-mvp": false
    }
  }
}
