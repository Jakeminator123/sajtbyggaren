{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "preview-runtime-policy.schema.json",
  "title": "Preview Runtime Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["policyId", "version", "status", "purpose", "principles", "default", "runtimes", "promotionRule", "qualityGate", "forbiddenTerms"],
  "properties": {
    "$schema": { "type": "string" },
    "policyId": { "type": "string", "pattern": "^preview-runtime-policy\\.v[0-9]+$" },
    "version": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["draft", "draft-but-authoritative", "stable", "deprecated"] },
    "purpose": { "type": "string" },
    "principles": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "default": { "enum": ["vercel-sandbox", "local", "stackblitz", "fly"] },
    "runtimes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "status", "useWhen", "limitations", "envInjection"],
        "properties": {
          "kind": { "enum": ["vercel-sandbox", "local", "stackblitz", "fly"] },
          "status": { "enum": ["primary", "secondary", "developer-only", "deprecated", "paused"] },
          "useWhen": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "limitations": { "type": "array", "items": { "type": "string" } },
          "envInjection": { "type": "string" }
        }
      }
    },
    "promotionRule": { "type": "string" },
    "qualityGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checks", "comment"],
      "properties": {
        "checks": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "comment": { "type": "string" }
      }
    },
    "forbiddenTerms": { "type": "array", "items": { "type": "string" } }
  }
}
