{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sajtbyggaren.local/schemas/scaffold.schema.json",
  "title": "Scaffold",
  "description": "Canonical schema for packages/generation/orchestration/scaffolds/<scaffoldId>/scaffold.json. Locks required scaffold identity and capability fields from scaffold-contract.v1.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "label",
    "description",
    "buildIntent",
    "primaryJobs",
    "defaultPageCount",
    "supportsSinglePage",
    "supportsMultiPage",
    "supportsAppFeatures"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "buildIntent": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "primaryJobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "defaultPageCount": {
      "type": "integer",
      "minimum": 1
    },
    "supportsSinglePage": {
      "type": "boolean"
    },
    "supportsMultiPage": {
      "type": "boolean"
    },
    "supportsAppFeatures": {
      "type": "boolean"
    }
  }
}
