{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "llm-flow-concepts.schema.json",
  "title": "LLM Flow Concepts",
  "type": "object",
  "additionalProperties": false,
  "required": ["policyId", "version", "status", "northStar", "phaseBlocks", "canonicalFlow", "phases", "terms"],
  "properties": {
    "$schema": { "type": "string" },
    "policyId": { "type": "string", "pattern": "^llm-flow-concepts\\.v[0-9]+$" },
    "version": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["draft", "draft-but-authoritative", "stable", "deprecated"] },
    "northStar": { "type": "string" },
    "phaseBlocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "phaseIds"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "label": { "type": "string" },
          "phaseIds": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      }
    },
    "canonicalFlow": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "order", "canonicalName", "purpose", "inputArtifacts", "outputArtifacts", "ownerPackage", "allowedToCallLLM", "mustNotDo"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "order": { "type": "integer", "minimum": 0 },
          "canonicalName": { "type": "string" },
          "purpose": { "type": "string" },
          "inputArtifacts": { "type": "array", "items": { "type": "string" } },
          "outputArtifacts": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "ownerPackage": { "type": "string" },
          "allowedToCallLLM": { "type": "boolean" },
          "mustNotDo": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "terms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["term", "id", "definition", "avoid"],
        "properties": {
          "term": { "type": "string" },
          "id": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$" },
          "definition": { "type": "string" },
          "avoid": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
