{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dossier.schema.json",
  "title": "Dossier Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "enabled",
    "label",
    "capability",
    "class",
    "codeFidelity",
    "complexity",
    "defaultForCapability",
    "summary",
    "envVars",
    "dependencies",
    "files",
    "exposes",
    "lastVerified"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "minLength": 1 },
    "enabled": { "type": "boolean", "default": true },
    "label": { "type": "string", "minLength": 1 },
    "capability": { "type": "string", "minLength": 1 },
    "class": { "enum": ["soft", "hard"] },
    "codeFidelity": { "type": "string", "minLength": 1 },
    "complexity": { "type": "string", "minLength": 1 },
    "defaultForCapability": { "type": "boolean" },
    "summary": { "type": "string", "minLength": 1 },
    "envVars": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "files": { "type": "array", "items": { "type": "string" } },
    "exposes": { "type": "array", "items": { "type": "string" } },
    "lastVerified": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  }
}
