{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "page-quality-traits.schema.json",
  "title": "Page Quality Traits",
  "type": "object",
  "additionalProperties": false,
  "required": ["policyId", "version", "status", "qualityTarget", "scoring", "traits"],
  "properties": {
    "$schema": { "type": "string" },
    "policyId": { "type": "string", "pattern": "^page-quality-traits\\.v[0-9]+$" },
    "version": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["draft", "draft-but-authoritative", "stable", "deprecated"] },
    "qualityTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scoreScale", "targetScore", "gateScore", "blockBelow", "label", "meaning"],
      "properties": {
        "scoreScale": { "const": "0-10" },
        "targetScore": { "type": "number", "minimum": 0, "maximum": 10 },
        "gateScore": { "type": "number", "minimum": 0, "maximum": 10 },
        "blockBelow": { "type": "number", "minimum": 0, "maximum": 10 },
        "label": { "type": "string" },
        "meaning": { "type": "string" }
      }
    },
    "scoring": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "weightsTotal", "rounding", "promotionRule"],
      "properties": {
        "method": { "enum": ["weighted_average"] },
        "weightsTotal": { "type": "integer", "const": 100 },
        "rounding": { "enum": ["one_decimal", "two_decimals"] },
        "promotionRule": { "type": "string" }
      }
    },
    "traits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "weight", "ownerPackage", "definition", "positiveSignals", "negativeSignals", "checkMethods"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "name": { "type": "string" },
          "weight": { "type": "integer", "minimum": 1, "maximum": 100 },
          "ownerPackage": { "type": "string" },
          "definition": { "type": "string" },
          "positiveSignals": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "negativeSignals": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "checkMethods": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      }
    }
  }
}
