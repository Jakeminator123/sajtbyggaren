{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "starter-registry.schema.json",
  "title": "Starter Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["policyId", "version", "status", "purpose", "principles", "starters"],
  "properties": {
    "$schema": { "type": "string" },
    "policyId": { "type": "string", "pattern": "^starter-registry\\.v[0-9]+$" },
    "version": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["draft", "draft-but-authoritative", "stable", "deprecated"] },
    "purpose": { "type": "string", "minLength": 1 },
    "principles": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "starters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "enabled", "label", "path", "status", "rationale"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "enabled": { "type": "boolean", "default": true },
          "label": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "pattern": "^data/starters/[a-z][a-z0-9-]*/$" },
          "status": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
