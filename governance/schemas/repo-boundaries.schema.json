{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repo-boundaries.schema.json",
  "title": "Repo Boundaries",
  "type": "object",
  "additionalProperties": false,
  "required": ["policyId", "version", "status", "purpose", "ownership", "globalRules"],
  "properties": {
    "$schema": { "type": "string" },
    "policyId": { "type": "string", "pattern": "^repo-boundaries\\.v[0-9]+$" },
    "version": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["draft", "draft-but-authoritative", "stable", "deprecated"] },
    "purpose": { "type": "string" },
    "ownership": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "owns", "mayImportFrom", "mustNotDo"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "owns": { "type": "array", "items": { "type": "string" } },
          "mayImportFrom": { "type": "array", "items": { "type": "string" } },
          "mustNotDo": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "globalRules": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
  }
}
