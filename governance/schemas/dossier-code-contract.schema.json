{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dossier-code-contract.schema.json",
  "title": "Dossier Code Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["must", "avoid"],
  "properties": {
    "$schema": { "type": "string" },
    "must": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "avoid": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
