node_modules
.venv/
__pycache__/
*.py[cod]

apps/viewser/node_modules
apps/viewser/.next

# Tool caches that bloat the indexer with no value for editing.
.pytest_cache/
.ruff_cache/
.mypy_cache/
.swc/
.turbo/

# ---------------------------------------------------------------------------
# Build outputs (Next.js + generic)
# ---------------------------------------------------------------------------

dist
build
.next
out
# .vercel: blockera secrets (pulled .env* fran `vercel pull`) men slapp in de
# tva ofarliga lank-metadata-filerna sa en agent kan se vilket Vercel-projekt
# repot ar lankat till. `.vercel/*` blockerar alla direkta barn (inkl.
# .env.*.local); !-raderna ater-tillater bara repo.json/project.json
# (team-/projekt-id, inga secrets).
.vercel/*
!.vercel/repo.json
!.vercel/project.json

# Reserve the destination for the B13a -move (see
# docs/known-issues.md). The bare `build` rule above matches at any
# depth, including `packages/generation/build/`, which would hide the
# new package from agent indexing once the move PR lands. Pre-allow
# it now so the trap is gone before anyone hits it.
!packages/generation/build/
!packages/generation/build/**

# ---------------------------------------------------------------------------
# Lockfiles - large JSON the indexer never needs for code search
# ---------------------------------------------------------------------------

# Lockfiles are committed (per `.gitignore`) and reproducibility
# tooling reads them on disk just fine; the Cursor indexer does not
# need to scan them when looking for code symbols. Excluding them
# trims one of the heaviest text payloads in the repo (each
# starter's `package-lock.json` is hundreds of KB).
package-lock.json
yarn.lock
pnpm-lock.yaml

# ---------------------------------------------------------------------------
# Engine Run artefakter och dev-output
# ---------------------------------------------------------------------------

# Each Engine Run drops 8 artefakter + a generated-files snapshot
# under `data/runs/<runId>/`. After a few dev-builder runs this grows
# fast and offers nothing the agent needs to read on every request.

################################################
#data/runs/
#data/versions/
#data/prompt-inputs/
#data/embedding-index/
#.generated/
################################################
# ---------------------------------------------------------------------------
# Env-filer (alla varianter); .env.example forblir lasbar
# ---------------------------------------------------------------------------

#.env
#.env.*
#!.env.example

# ---------------------------------------------------------------------------
# Starter-public binary assets
# ---------------------------------------------------------------------------

# Each starter's `public/` carries vendor logos, hero images, fonts.
# They blow up the indexer with binary content the agent cannot
# meaningfully use. README/JSON inside public/ stays indexable via
# the explicit re-include lines below.
data/starters/**/public/**/*.png
data/starters/**/public/**/*.jpg
data/starters/**/public/**/*.jpeg
data/starters/**/public/**/*.gif
data/starters/**/public/**/*.webp
data/starters/**/public/**/*.svg
data/starters/**/public/**/*.ico
data/starters/**/public/**/*.avif
data/starters/**/public/**/*.woff
data/starters/**/public/**/*.woff2
data/starters/**/public/**/*.ttf
data/starters/**/public/**/*.eot
!data/starters/**/public/**/*.md
!data/starters/**/public/**/*.txt
!data/starters/**/public/**/*.json

# ---------------------------------------------------------------------------
# Operator-only material som inte ska indexeras av Cursor
# ---------------------------------------------------------------------------

.git/
.review-*/
.streamlit/secrets.toml
#.cursor/mcp.json
# Agent-/operator-lokala plan-filer och temp-noteringar (.cursor/tmp_*).
# Redan gitignored; här blockerar vi även agentens Read + sökindex så
# scratch inte förorenar codebase-sök. Samma kategori som .cursor/mcp.json.
.cursor/plans/
.cursor/tmp_*
.vscode/*.local.json

# ---------------------------------------------------------------------------
# Tmp och logs
# ---------------------------------------------------------------------------

*.log
.tmp-*
.tmp.*
.commit-msg.tmp
# Lokal mini-eval-output (samma kategori som data/runs/ men operatör-lokal).
eval-tmp/

# Global binary payloads should never be indexed
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.svg
*.avif
*.woff
*.woff2
*.ttf
*.eot
*.zip
*.rar
*.tar
*.tar.gz
*.tgz
*.7z
*.pdf
*.mp4

övrigt/

data/output/
