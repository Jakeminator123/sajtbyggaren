# Dependency and build outputs
node_modules
dist
build
.next
out
.turbo
# Reserve the destination for the B13a architecture-move (see
# docs/known-issues.md). The bare `build` rule above matches at any
# depth, including packages/generation/build/, which would hide the
# new package from agent indexing once the move PR lands. Pre-allow it
# now so the trap is gone before anyone hits it.
!packages/generation/build/
!packages/generation/build/**

# Python caches and venv
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Engine Run artefakter och dev-output
data/runs/
data/versions/
data/prompt-inputs/
.generated/

# Env-filer (alla varianter); .env.example forblir lasbar
.env
.env.*
!.env.example

# Operator-only material som inte ska indexeras av Cursor
MIN_IDE/

# Tunga binarer under referens/. Text-utlatanden och .json/.md/.txt-content
# dar ar fortsatt sokbara for agenten - bara binarfiler ignoreras.
referens/**/*.png
referens/**/*.jpg
referens/**/*.jpeg
referens/**/*.gif
referens/**/*.webp
referens/**/*.zip
referens/**/*.rar
referens/**/*.tar
referens/**/*.tar.gz
referens/**/*.tgz
referens/**/*.7z
referens/**/*.pdf

# Tmp och logs
*.log
.tmp-*
.tmp.*

referens/