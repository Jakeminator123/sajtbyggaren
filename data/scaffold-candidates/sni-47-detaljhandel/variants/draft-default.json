{
  "$schema": "../../../../governance/schemas/variant.schema.json",
  "id": "draft-default",
  "enabled": false,
  "label": "Draft Default",
  "description": "Startvariant kopierad från referens-scaffoldens default så kandidaten kan förhandsgranskas; ersätts vid kurering.",
  "tokens": {
    "color": {
      "background": "#fbfaf7",
      "foreground": "#1a1a1a",
      "muted": "#6e6e68",
      "border": "#e8e6e0",
      "primary": "#1a1a1a",
      "primaryForeground": "#fbfaf7",
      "accent": "#c9a87c",
      "accentForeground": "#1a1a1a"
    },
    "typography": {
      "fontFamilyDisplay": "var(--font-geist-sans)",
      "fontFamilyBody": "var(--font-geist-sans)",
      "fontFamilyMono": "var(--font-geist-mono)",
      "scaleRatio": 1.25
    },
    "radius": {
      "sm": "0.25rem",
      "md": "0.375rem",
      "lg": "0.5rem"
    },
    "spacing": {
      "section": "6rem",
      "container": "min(76rem, 92vw)"
    },
    "motion": {
      "level": "subtle"
    }
  },
  "tone": {
    "vibe": [
      "editorial",
      "premium-but-restrained",
      "product-led",
      "calm"
    ]
  }
}
