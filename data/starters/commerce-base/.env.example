# Optional display names used by the starter shell.
COMPANY_NAME="Commerce Base"
SITE_NAME="Commerce Base"

# Optional Shopify adapter. Leave these empty to build commerce-base
# without live Shopify data. Set STORE_DOMAIN and STOREFRONT_ACCESS_TOKEN
# together when enabling the adapter.
SHOPIFY_REVALIDATION_SECRET=""
SHOPIFY_STOREFRONT_ACCESS_TOKEN=""
SHOPIFY_STORE_DOMAIN=""
